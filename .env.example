# Connection string de Supabase: Project Settings > Database > Connection string (modo "Session pooler" o directo)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# Usuarios habilitados para entrar a la app (separados por coma, sin espacios)
# El login es simple: nombre + clave compartida por usuario, pensado para 2 socios, no para una empresa con muchos usuarios.
APP_USERS=nacho:clave1,facu:clave2
